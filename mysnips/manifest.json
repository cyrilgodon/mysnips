{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.3.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": ["storage", "contextMenus", "scripting", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "MySnips"
  },
  "commands": {
    "open-panel": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Ouvrir MySnips"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
